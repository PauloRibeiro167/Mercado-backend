#!/usr/bin/env ruby
require 'bundler/setup'
require 'fileutils'
require_relative '../config/application'

# Aceita o caminho do arquivo de saída como argumento
# Padrão: erd.pdf na pasta Docs do projeto
default_path = File.join(__dir__, '../../Docs/erd.pdf')
output_file = ARGV[0] || default_path

# Apagar o arquivo ERD existente antes de gerar um novo
File.delete(output_file) if File.exist?(output_file)

# Executar a tarefa Rake erd:generate no diretório da aplicação
success = Dir.chdir(Rails.root) do
	system('bundle exec rake erd:generate')
end

unless success
	warn 'Falha ao executar bundle exec rake erd:generate.'
	exit 1
end

# Mover o arquivo gerado para o caminho desejado
generated_file = File.join(Rails.root.to_s, 'erd.pdf')

if File.exist?(generatbed_file)
  FileUtils.mkdir_p(File.dirname(output_file))
	FileUtils.mv(generated_file, output_file, force: true)
	puts "ERD movido para #{output_file}"
else
	warn 'Falha ao localizar o arquivo erd.pdf após a geração.'
	exit 1
end
